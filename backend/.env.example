# Postgres connection
PGHOST=localhost
PGPORT=5432
PGUSER=swecha_app
PGPASSWORD=changeme
PGDATABASE=swecha_website

# API server
PORT=4000
# Set this to your site's URL once deployed, e.g. https://yourswecha.com
CORS_ORIGIN=*

# Auth
# Generate with: openssl rand -base64 48
JWT_SECRET=changeme-generate-a-long-random-string

# SMTP for contact/quote/catalogue email notifications
# (Hostinger email, Gmail with an app password, or any SMTP provider)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_TO=
